#!/bin/sh
# zig-cxx — wraps `zig c++` as a C++ compiler for CGO cross-compilation.
# Usage: CXX="zig-cxx linux arm64" go build ...
set -e

GOOS="$1"
GOARCH="$2"
shift 2

case "${GOOS}-${GOARCH}" in
  linux-amd64)   TARGET="x86_64-linux-musl" ;;
  linux-arm64)   TARGET="aarch64-linux-musl" ;;
  darwin-amd64)  TARGET="x86_64-macos"      ;;
  darwin-arm64)  TARGET="aarch64-macos"      ;;
  windows-amd64) TARGET="x86_64-windows-gnu" ;;
  *) echo "zig-cxx: unsupported ${GOOS}/${GOARCH}" >&2; exit 1 ;;
esac

exec zig c++ -target "${TARGET}" "$@"
