#!/bin/bash
# zig-cc — wraps `zig cc` as a C compiler for CGO cross-compilation.
# Usage: CC="zig-cc linux arm64" go build ...
#
# When the target matches the host, falls back to the native clang to avoid
# needing the macOS SDK in zig's cross-compilation environment.
set -e

GOOS="$1"
GOARCH="$2"
shift 2

case "${GOOS}-${GOARCH}" in
  linux-amd64)   TARGET="x86_64-linux-musl" ;;
  linux-arm64)   TARGET="aarch64-linux-musl" ;;
  darwin-amd64)  TARGET="x86_64-macos"      ;;
  darwin-arm64)  TARGET="aarch64-macos"      ;;
  windows-amd64) TARGET="x86_64-windows-gnu" ;;
  *) echo "zig-cc: unsupported ${GOOS}/${GOARCH}" >&2; exit 1 ;;
esac

HOST_OS=$(uname -s | tr '[:upper:]' '[:lower:]')
HOST_ARCH=$(uname -m)
[ "${HOST_ARCH}" = "aarch64" ] && HOST_ARCH="arm64"
[ "${HOST_ARCH}" = "x86_64"  ] && HOST_ARCH="amd64"

# Native build: let the system compiler handle it.
if [ "${GOOS}" = "${HOST_OS}" ] && [ "${GOARCH}" = "${HOST_ARCH}" ]; then
  exec clang "$@"
fi

# Cross-compiling to darwin: strip -lresolv (part of libSystem, unavailable
# in zig's cross-compilation environment).
if [ "${GOOS}" = "darwin" ]; then
  args=()
  for arg in "$@"; do
    [ "${arg}" = "-lresolv" ] && continue
    args+=("${arg}")
  done
  exec zig cc -target "${TARGET}" "${args[@]}"
fi

exec zig cc -target "${TARGET}" "$@"
